<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Sistema de Diferidos</title>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;600;700&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
:root {
  --black: #0a0a0a;
  --white: #ffffff;
  --g100: #f7f7f7;
  --g200: #ebebeb;
  --g300: #d4d4d4;
  --g500: #8a8a8a;
  --g700: #464646;
  --g900: #1c1c1c;
  --accent: #b8965a;
  --green: #2a7a4b;
  --red: #b83232;
  --amber: #a06c1a;
  --fd: 'Playfair Display', Georgia, serif;
  --fb: 'DM Sans', system-ui, sans-serif;
  --sh: 0 2px 24px rgba(0,0,0,0.07);
  --r: 6px;
}
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
html{scroll-behavior:smooth}
body{font-family:var(--fb);background:var(--g100);color:var(--black);min-height:100vh;font-size:14px;line-height:1.6}

/* ─── HEADER ─── */
header{background:var(--black);color:var(--white);padding:0 2.5rem;position:sticky;top:0;z-index:100;height:64px;display:flex;align-items:center;justify-content:space-between;border-bottom:1px solid rgba(255,255,255,0.06)}
.brand{display:flex;align-items:center;gap:14px;text-decoration:none}
.brand-logo{width:38px;height:38px;object-fit:contain;filter:brightness(0) invert(1);border-radius:4px;flex-shrink:0}
.brand-logo-fallback{width:38px;height:38px;background:rgba(255,255,255,0.12);border-radius:4px;display:flex;align-items:center;justify-content:center;font-size:18px;font-family:var(--fd);color:var(--white);font-weight:700;flex-shrink:0}
.brand-text .name{font-family:var(--fd);font-size:1.05rem;font-weight:600;color:var(--white);letter-spacing:.01em}
.brand-text .sub{font-size:.65rem;color:rgba(255,255,255,.45);text-transform:uppercase;letter-spacing:.1em}
nav{display:flex;gap:4px}
.nb{background:transparent;border:none;color:rgba(255,255,255,.55);font-family:var(--fb);font-size:.75rem;font-weight:600;letter-spacing:.07em;text-transform:uppercase;cursor:pointer;padding:8px 16px;border-radius:4px;transition:all .2s}
.nb:hover{color:var(--white);background:rgba(255,255,255,.08)}
.nb.active{color:var(--white);background:rgba(255,255,255,.13)}

/* ─── PAGES ─── */
.page{display:none}
.page.active{display:block}
.container{max-width:880px;margin:0 auto;padding:2.5rem 1.25rem}

/* ─── SECTION HEADER ─── */
.sh{text-align:center;margin-bottom:2.5rem}
.sh h1{font-family:var(--fd);font-size:2rem;font-weight:600;color:var(--black);margin-bottom:.5rem}
.sh p{color:var(--g500);font-size:.88rem}

/* ─── STEPS ─── */
.steps{display:flex;align-items:flex-start;justify-content:center;margin-bottom:2.5rem}
.si{display:flex;flex-direction:column;align-items:center;gap:7px;flex:1;max-width:180px;position:relative}
.si:not(:last-child)::after{content:'';position:absolute;top:17px;left:calc(50% + 20px);width:calc(100% - 40px);height:2px;background:var(--g200);z-index:0;transition:background .3s}
.si.done:not(:last-child)::after{background:var(--black)}
.sn{width:36px;height:36px;border-radius:50%;border:2px solid var(--g300);display:flex;align-items:center;justify-content:center;font-weight:700;font-size:.82rem;background:var(--white);color:var(--g500);z-index:1;transition:all .3s}
.si.active .sn{border-color:var(--black);background:var(--black);color:var(--white)}
.si.done .sn{border-color:var(--black);background:var(--black);color:var(--white)}
.si.done .sn::before{content:'✓';font-size:.9rem}
.si.done .sn .sn-num{display:none}
.sl{font-size:.7rem;text-transform:uppercase;letter-spacing:.07em;color:var(--g500);font-weight:500;text-align:center}
.si.active .sl{color:var(--black);font-weight:600}
.si.done .sl{color:var(--g700)}

/* ─── CARD ─── */
.card{background:var(--white);border-radius:var(--r);padding:2rem;box-shadow:var(--sh);border:1px solid var(--g200);margin-bottom:1.5rem;animation:fi .3s ease}
@keyframes fi{from{opacity:0;transform:translateY(10px)}to{opacity:1;transform:translateY(0)}}
.ct{font-family:var(--fd);font-size:1.05rem;font-weight:600;margin-bottom:1.5rem;padding-bottom:1rem;border-bottom:1px solid var(--g200);color:var(--black);display:flex;align-items:center;justify-content:space-between}
.ct small{font-family:var(--fb);font-size:.75rem;font-weight:400;color:var(--g500)}

/* ─── FORM ─── */
.fg2{display:grid;grid-template-columns:1fr 1fr;gap:1.25rem}
.fg1{display:grid;grid-template-columns:1fr;gap:1.25rem}
.fg{display:flex;flex-direction:column;gap:6px}
.fg.full{grid-column:1/-1}
label{font-size:.68rem;font-weight:700;text-transform:uppercase;letter-spacing:.09em;color:var(--g700)}
label span.hint{font-weight:400;text-transform:none;letter-spacing:0;color:var(--g500);font-size:.7rem}
input[type=text],input[type=date],input[type=number],input[type=email],input[type=password],select,textarea{border:none;border-bottom:2px solid var(--g200);border-radius:0;padding:10px 0;font-family:var(--fb);font-size:.9rem;color:var(--black);background:transparent;outline:none;transition:border-color .2s;width:100%;-webkit-appearance:none}
input:focus,select:focus,textarea:focus{border-bottom-color:var(--black)}
textarea{resize:vertical;min-height:80px}
.ie{font-size:.7rem;color:var(--red);display:none;margin-top:2px}
.he .ie{display:block}
.he input,.he select{border-bottom-color:var(--red)}

/* ─── AUTOCOMPLETE ─── */
.acw{position:relative}
.acl{position:absolute;top:calc(100% + 4px);left:0;right:0;background:var(--white);border:1px solid var(--g200);border-radius:var(--r);box-shadow:0 8px 28px rgba(0,0,0,.12);z-index:300;max-height:210px;overflow-y:auto;display:none}
.acl.open{display:block}
.aci{padding:10px 14px;cursor:pointer;font-size:.87rem;transition:background .15s;display:flex;align-items:center;justify-content:space-between}
.aci:hover,.aci.sel{background:var(--g100)}
.atag{font-size:.62rem;text-transform:uppercase;letter-spacing:.07em;padding:2px 7px;border-radius:2px;font-weight:700}
.t-direct{background:var(--black);color:var(--white)}
.t-agency{background:var(--g200);color:var(--g700)}
.t-special{background:var(--accent);color:var(--white)}

/* ─── PAYMENT ENTRY ─── */
.pe{border:1px solid var(--g200);border-radius:var(--r);padding:1.5rem;margin-bottom:1rem;background:var(--g100)}
.peh{display:flex;align-items:center;justify-content:space-between;margin-bottom:1rem;font-size:.72rem;font-weight:700;text-transform:uppercase;letter-spacing:.1em;color:var(--g500)}
.rmbtn{background:none;border:none;color:var(--g500);cursor:pointer;font-size:1.4rem;line-height:1;padding:2px 6px;border-radius:3px;transition:all .2s}
.rmbtn:hover{color:var(--red);background:rgba(184,50,50,.08)}
.btag{display:inline-flex;align-items:center;gap:5px;font-size:.68rem;padding:4px 10px;border-radius:20px;font-weight:700;text-transform:uppercase;letter-spacing:.05em;margin-top:6px}
.bd{background:var(--black);color:var(--white)}
.ba{background:var(--g200);color:var(--g700)}

/* ─── PREVIEW BOX ─── */
.pvbox{background:var(--black);color:var(--white);border-radius:var(--r);padding:1.5rem;margin-top:1.5rem}
.pvtitle{font-family:var(--fd);font-size:.95rem;font-weight:600;margin-bottom:1rem;padding-bottom:.75rem;border-bottom:1px solid rgba(255,255,255,.12)}
.pvr{display:flex;justify-content:space-between;align-items:center;padding:7px 0;border-bottom:1px solid rgba(255,255,255,.07);font-size:.87rem}
.pvr:last-child{border-bottom:none}
.pvl{color:rgba(255,255,255,.55)}
.pvv{font-weight:600}
.pvv.hl{color:var(--accent)}
.pv-empty{text-align:center;padding:1.5rem;color:rgba(255,255,255,.3);font-style:italic;font-size:.85rem}

/* ─── BUTTONS ─── */
.btn{display:inline-flex;align-items:center;gap:8px;padding:11px 24px;border-radius:4px;font-family:var(--fb);font-size:.78rem;font-weight:700;text-transform:uppercase;letter-spacing:.08em;cursor:pointer;border:2px solid transparent;transition:all .2s}
.btn-p{background:var(--black);color:var(--white);border-color:var(--black)}
.btn-p:hover{background:var(--g900)}
.btn-s{background:transparent;color:var(--black);border-color:var(--g300)}
.btn-s:hover{border-color:var(--black)}
.btn-ghost{background:transparent;color:var(--g500);border:none;padding:8px 12px;font-size:.75rem}
.btn-ghost:hover{color:var(--black)}
.btn-add{background:transparent;color:var(--black);border:2px dashed var(--g300);width:100%;justify-content:center;padding:12px;font-size:.78rem}
.btn-add:hover{border-color:var(--black);background:var(--g100)}
.btn-row{display:flex;justify-content:space-between;align-items:center;margin-top:2rem;padding-top:1.5rem;border-top:1px solid var(--g200)}
.btn-ok{background:#2a7a4b;color:var(--white);border-color:#2a7a4b}
.btn-ok:hover{background:#1f5e39}
.btn-no{background:#b83232;color:var(--white);border-color:#b83232}
.btn-no:hover{background:#8c2626}

/* ─── BADGES ─── */
.badge{display:inline-flex;align-items:center;gap:5px;padding:3px 10px;border-radius:20px;font-size:.67rem;font-weight:700;text-transform:uppercase;letter-spacing:.06em}
.badge::before{content:'';width:5px;height:5px;border-radius:50%;background:currentColor}
.b-pend{background:#fef9ec;color:#a06c1a;border:1px solid #f0cf7a}
.b-appr{background:#eefaf3;color:#2a7a4b;border:1px solid #9de5bc}
.b-reje{background:#fdf0f0;color:#b83232;border:1px solid #f5b8b8}

/* ─── TABLE / REQUESTS ─── */
.toolbar{display:flex;gap:.75rem;margin-bottom:1.5rem;align-items:center;flex-wrap:wrap}
.si-input{flex:1;min-width:200px;border:1px solid var(--g200)!important;border-radius:4px!important;padding:9px 14px!important;font-size:.85rem}
.sf-select{border:1px solid var(--g200)!important;border-radius:4px!important;padding:9px 14px!important;background:var(--white)!important;cursor:pointer}
table{width:100%;border-collapse:collapse;font-size:.84rem}
th{text-align:left;padding:9px 12px;font-size:.65rem;text-transform:uppercase;letter-spacing:.09em;color:var(--g500);border-bottom:2px solid var(--g200);font-weight:700}
td{padding:11px 12px;border-bottom:1px solid var(--g100);vertical-align:middle}
tr:hover td{background:var(--g100)}
.no-data{text-align:center;padding:3rem;color:var(--g500);font-style:italic;font-size:.9rem}

/* ─── STATS ─── */
.stats{display:grid;grid-template-columns:repeat(3,1fr);gap:1rem;margin-bottom:2rem}
.sc{background:var(--white);border:1px solid var(--g200);border-radius:var(--r);padding:1.25rem;text-align:center}
.sn{font-family:var(--fd);font-size:2.2rem;font-weight:700;margin-bottom:3px}
.sl2{font-size:.68rem;text-transform:uppercase;letter-spacing:.09em;color:var(--g500);font-weight:700}

/* ─── CREDITS LOGIN ─── */
.login-wrap{max-width:400px;margin:3rem auto;text-align:center}
.lock{font-size:2.5rem;margin-bottom:1.5rem}
.pin-input{border:2px solid var(--g200)!important;border-radius:4px!important;padding:14px!important;text-align:center;letter-spacing:.2em;font-size:1.2rem!important;background:var(--white)!important}
.pin-input:focus{border-color:var(--black)!important}
.pw-err{color:var(--red);font-size:.8rem;text-align:center;margin-top:8px;display:none}

/* ─── MODAL ─── */
.overlay{position:fixed;inset:0;background:rgba(0,0,0,.65);z-index:1000;display:none;align-items:center;justify-content:center;padding:1rem;backdrop-filter:blur(4px)}
.overlay.open{display:flex}
.modal{background:var(--white);border-radius:8px;width:100%;max-width:660px;max-height:90vh;overflow-y:auto;box-shadow:0 24px 64px rgba(0,0,0,.35)}
.mh{padding:1.5rem 2rem;border-bottom:1px solid var(--g200);display:flex;align-items:center;justify-content:space-between;position:sticky;top:0;background:var(--white);z-index:1}
.mh h3{font-family:var(--fd);font-size:1.1rem}
.mc-btn{background:none;border:none;font-size:1.6rem;cursor:pointer;color:var(--g500);line-height:1;padding:2px 6px}
.mc-btn:hover{color:var(--black)}
.mb{padding:2rem}
.dg{display:grid;grid-template-columns:1fr 1fr;gap:1rem}
.di .dl{font-size:.65rem;font-weight:700;text-transform:uppercase;letter-spacing:.09em;color:var(--g500);margin-bottom:3px}
.di .dv{font-size:.88rem;color:var(--black);font-weight:500}
.ma{display:flex;gap:.75rem;flex-wrap:wrap;padding:1.5rem 2rem;border-top:1px solid var(--g200);background:var(--g100)}

/* ─── EMAIL SECTION ─── */
.email-box{border:1px solid var(--g200);border-radius:var(--r);padding:1.25rem;margin-top:1.25rem}
.email-box-title{font-size:.68rem;font-weight:700;text-transform:uppercase;letter-spacing:.09em;color:var(--g700);margin-bottom:1rem}
.email-box input,.email-box textarea,.email-box select{border:1px solid var(--g200)!important;border-radius:4px!important;padding:9px 12px!important;margin-bottom:.6rem;background:var(--white)!important}
.email-box input:focus,.email-box textarea:focus{border-color:var(--black)!important;outline:none}

/* ─── SCENARIO ALERTS ─── */
.alert{display:flex;align-items:flex-start;gap:10px;padding:12px 16px;border-radius:4px;font-size:.82rem;margin-top:.75rem}
.a-pend{background:#fef9ec;border:1px solid #f0cf7a;color:#7d4f00}
.a-ok{background:#eefaf3;border:1px solid #9de5bc;color:#1a5c38}
.a-block{background:#fdf0f0;border:1px solid #f5b8b8;color:#6e1f1f}

/* ─── RANGE ─── */
.rw{display:flex;align-items:center;gap:1rem}
input[type=range]{border:none!important;border-bottom:none!important;-webkit-appearance:none;height:4px;background:var(--g200);border-radius:2px;flex:1;padding:0!important;cursor:pointer}
input[type=range]::-webkit-slider-thumb{-webkit-appearance:none;width:20px;height:20px;border-radius:50%;background:var(--black);cursor:pointer;box-shadow:0 2px 8px rgba(0,0,0,.2)}
.rv{font-size:1.1rem;font-weight:700;min-width:55px;text-align:right}

/* ─── SUMMARY ─── */
.sum-sec{margin-bottom:1.25rem}
.sum-sec-title{font-size:.67rem;font-weight:700;text-transform:uppercase;letter-spacing:.1em;color:var(--g500);margin-bottom:.6rem;padding-bottom:.4rem;border-bottom:1px solid var(--g200)}
.sum-row{display:flex;justify-content:space-between;padding:5px 0;font-size:.87rem}
.sum-lbl{color:var(--g700)}
.sum-val{font-weight:500;text-align:right;max-width:60%}

/* ─── TOAST ─── */
.toast{position:fixed;bottom:2rem;right:2rem;background:var(--black);color:var(--white);padding:.9rem 1.5rem;border-radius:6px;font-size:.84rem;font-weight:500;z-index:2000;transform:translateY(120px);opacity:0;transition:all .3s;box-shadow:0 8px 28px rgba(0,0,0,.3);max-width:340px}
.toast.show{transform:translateY(0);opacity:1}

/* ─── SCROLLBAR ─── */
::-webkit-scrollbar{width:6px}
::-webkit-scrollbar-track{background:var(--g100)}
::-webkit-scrollbar-thumb{background:var(--g300);border-radius:3px}

/* ─── RESPONSIVE ─── */
@media(max-width:640px){
  .fg2{grid-template-columns:1fr}
  .dg{grid-template-columns:1fr}
  .btn-row{flex-direction:column;gap:.75rem}
  header{padding:0 1rem}
  .brand-text .sub{display:none}
  .steps{gap:0}
  .stats{grid-template-columns:1fr}
  nav .nb{padding:8px 10px;font-size:.7rem}
}
</style>
</head>
<body>

<!-- HEADER -->
<header>
  <div class="brand">
    <img src="https://encrypted-tbn0.gstatic.com/images?q=tbn:ANd9GcQlUU8q4mO1agavOb26p12dZ5ryKNxxeBrYlA&s"
         class="brand-logo" alt="Logo"
         onerror="this.style.display='none';document.getElementById('logo-fb').style.display='flex'">
    <div class="brand-logo-fallback" id="logo-fb" style="display:none">C</div>
    <div class="brand-text">
      <div class="name">Sistema de Diferidos</div>
      <div class="sub">Credit Department · US Insurance</div>
    </div>
  </div>
  <nav>
    <button class="nb active" onclick="showPage('home')" id="nav-home">Nueva Solicitud</button>
    <button class="nb" onclick="showPage('requests')" id="nav-requests">Solicitudes</button>
    <button class="nb" onclick="showPage('credits')" id="nav-credits">Área de Créditos</button>
  </nav>
</header>

<!-- ═══════════════════════════════════════════════════
     PAGE 1: NUEVA SOLICITUD
     ═══════════════════════════════════════════════════ -->
<div id="page-home" class="page active">
  <div class="container">
    <div class="sh">
      <h1>Nueva Solicitud de Diferido</h1>
      <p>Complete los tres pasos para enviar la solicitud al área de créditos</p>
    </div>

    <!-- STEP INDICATOR -->
    <div class="steps">
      <div class="si active" id="si1"><div class="sn"><span class="sn-num">1</span></div><div class="sl">Inicio</div></div>
      <div class="si" id="si2"><div class="sn"><span class="sn-num">2</span></div><div class="sl">Pago Diferido</div></div>
      <div class="si" id="si3"><div class="sn"><span class="sn-num">3</span></div><div class="sl">Confirmación</div></div>
    </div>

    <!-- STEP 1 -->
    <div id="step-1">
      <div class="card">
        <div class="ct">Información del Agente</div>
        <div class="fg2">
          <div class="fg" id="g-agenteName">
            <label>Nombre del Agente *</label>
            <input type="text" id="agenteName" placeholder="Nombre completo del agente">
            <span class="ie">Campo requerido</span>
          </div>
          <div class="fg" id="g-agenteEmail">
            <label>Correo Electrónico *</label>
            <input type="email" id="agenteEmail" placeholder="correo@agencia.com">
            <span class="ie">Ingrese un correo válido</span>
          </div>
          <div class="fg" id="g-referencia">
            <label>Referencia *</label>
            <input type="text" id="referencia" placeholder="Ref. del cliente o póliza">
            <span class="ie">Campo requerido</span>
          </div>
          <div class="fg" id="g-dot">
            <label>DOT *</label>
            <input type="text" id="dot" placeholder="Número DOT">
            <span class="ie">Campo requerido</span>
          </div>
        </div>
      </div>

      <div id="payments-wrap"></div>

      <button class="btn btn-add" onclick="addPayment()">+ Añadir Pago / Póliza Adicional</button>

      <div class="btn-row">
        <span style="font-size:.8rem;color:var(--g500)">Paso 1 de 3</span>
        <button class="btn btn-p" onclick="nextStep(1)">Continuar →</button>
      </div>
    </div>

    <!-- STEP 2 -->
    <div id="step-2" style="display:none">
      <div id="pd-wrap"></div>
      <div class="btn-row">
        <button class="btn btn-s" onclick="prevStep(2)">← Volver</button>
        <button class="btn btn-p" onclick="nextStep(2)">Continuar →</button>
      </div>
    </div>

    <!-- STEP 3 -->
    <div id="step-3" style="display:none">
      <div class="card">
        <div class="ct">Resumen de la Solicitud</div>
        <div id="summary-html"></div>
      </div>
      <div class="card">
        <div class="ct">Estado de la Solicitud</div>
        <div id="eval-html"></div>
      </div>
      <div class="btn-row">
        <button class="btn btn-s" onclick="prevStep(3)">← Volver</button>
        <button class="btn btn-p" onclick="submitRequest()">Enviar Solicitud ✓</button>
      </div>
    </div>
  </div>
</div>

<!-- ═══════════════════════════════════════════════════
     PAGE 2: SOLICITUDES
     ═══════════════════════════════════════════════════ -->
<div id="page-requests" class="page">
  <div class="container">
    <div class="sh">
      <h1>Solicitudes</h1>
      <p>Historial de todas las solicitudes de diferidos del área comercial</p>
    </div>
    <div class="card">
      <div class="toolbar">
        <input type="text" class="si-input" id="srch" placeholder="Buscar por agente, referencia, DOT…" oninput="renderReqList()">
        <select class="sf-select" id="sf-status" onchange="renderReqList()">
          <option value="">Todos los estados</option>
          <option value="pending">Pendiente</option>
          <option value="approved">Aprobado</option>
          <option value="rejected">Rechazado</option>
        </select>
        <select class="sf-select" id="sf-date" onchange="renderReqList()">
          <option value="">Cualquier fecha</option>
          <option value="today">Hoy</option>
          <option value="week">Esta semana</option>
          <option value="month">Este mes</option>
        </select>
      </div>
      <div id="req-list"></div>
    </div>
  </div>
</div>

<!-- ═══════════════════════════════════════════════════
     PAGE 3: ÁREA DE CRÉDITOS
     ═══════════════════════════════════════════════════ -->
<div id="page-credits" class="page">
  <div class="container">

    <!-- LOGIN -->
    <div id="cr-login">
      <div class="login-wrap">
        <div class="lock">🔒</div>
        <div class="sh" style="margin-bottom:1.5rem">
          <h1>Área de Créditos</h1>
          <p>Acceso restringido al departamento de créditos</p>
        </div>
        <div class="card">
          <div class="fg">
