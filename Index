<!-- TOAST -->
<div class="toast" id="toast"></div>

<script>
// ================================================================
// DATA DEFINITIONS
// ================================================================

const COMPANIES = [
  { name:'Progressive',              billing:'agency_bill', autoStudy:true },
  { name:'Gainsco',                  billing:'direct_bill', selfFinance:true },
  { name:'Dairyland',                billing:'direct_bill', selfFinance:true },
  { name:'Bristol West',             billing:'direct_bill', selfFinance:true },
  { name:'Infinity',                 billing:'direct_bill', selfFinance:true },
  { name:'The General',              billing:'direct_bill', selfFinance:true },
  { name:'Safe Auto',                billing:'direct_bill', selfFinance:true },
  { name:'Foremost',                 billing:'direct_bill', selfFinance:true },
  { name:'National Lloyds',          billing:'direct_bill', selfFinance:true },
  { name:'National General',         billing:'agency_bill' },
  { name:'Kemper',                   billing:'agency_bill' },
  { name:'Travelers',                billing:'agency_bill' },
  { name:'Markel',                   billing:'agency_bill' },
  { name:'Hallmark',                 billing:'agency_bill' },
  { name:'State National',           billing:'agency_bill' },
  { name:'Occidental Fire & Casualty',billing:'agency_bill'},
  { name:'Victoria',                 billing:'agency_bill' },
  { name:'Integon',                  billing:'agency_bill' },
  { name:'AmTrust',                  billing:'agency_bill' },
  { name:'GuideOne',                 billing:'agency_bill' },
];

const FINANCIERAS = [
  { name:'Progressive',                    autoStudy:true  },
  { name:'IPFS',                           autoStudy:false },
  { name:'First Insurance Funding (FIFC)', autoStudy:false },
  { name:'Imperial Premium Finance',       autoStudy:false },
  { name:'Equity Premium Finance',         autoStudy:false },
  { name:'AFCO Credit Corporation',        autoStudy:false },
  { name:'Budget Premium Finance',         autoStudy:false },
  { name:'AssuredPartners',               autoStudy:false },
  { name:'All Risks Ltd.',                 autoStudy:false },
  { name:'Burns & Wilcox',                 autoStudy:false },
  { name:'AmTrust MGA',                    autoStudy:false },
  { name:'Dual Specialty',                 autoStudy:false },
  { name:'Nexus MGA',                      autoStudy:false },
];

// ================================================================
// STATE
// ================================================================

let S = {
  step: 1,
  creditAuth: false,
  payments: [],
  evalResult: null,
  snapForm: null,
  reviewId: null
};

// ================================================================
// STORAGE
// ================================================================

const LS_KEY = 'dif_requests_v1';
function getReqs(){ try{ return JSON.parse(localStorage.getItem(LS_KEY)||'[]') }catch{return[]} }
function saveReqs(arr){ localStorage.setItem(LS_KEY,JSON.stringify(arr)) }
function upsertReq(req){
  const a=getReqs(), i=a.findIndex(r=>r.id===req.id);
  if(i>=0) a[i]=req; else a.unshift(req);
  saveReqs(a);
}

// ================================================================
// PAYMENT OBJECT FACTORY
// ================================================================

function mkPay(){
  return {
    id: Date.now()+Math.random(),
    compania:'', companiaObj:null,
    financiera:'', financieraObj:null,
    billing:'', selfFin:false,
    // Step 2 fields
    totalDP:'', fechaP1:'',
    pctP1:70, diasP2:'', comentarios:''
  };
}

function initPayments(){
  S.payments = [mkPay()];
  renderPays();
}

// ================================================================
// NAVIGATION
// ================================================================

function showPage(p){
  document.querySelectorAll('.page').forEach(x=>x.classList.remove('active'));
  document.querySelectorAll('.nb').forEach(x=>x.classList.remove('active'));
  document.getElementById('page-'+p).classList.add('active');
  document.getElementById('nav-'+p).classList.add('active');
  if(p==='requests') renderReqList();
  if(p==='credits'){
    if(!S.creditAuth){
      document.getElementById('cr-login').style.display='block';
      document.getElementById('cr-dash').style.display='none';
    } else renderCrDash();
  }
}

// ================================================================
// STEP NAVIGATION
// ================================================================

function gotoStep(n){
  for(let i=1;i<=3;i++){
    const el=document.getElementById('step-'+i);
    if(el) el.style.display=(i===n?'block':'none');
    const si=document.getElementById('si'+i);
    if(si){
      si.classList.remove('active','done');
      if(i<n) si.classList.add('done');
      if(i===n) si.classList.add('active');
    }
  }
  S.step=n;
  window.scrollTo({top:0,behavior:'smooth'});
}

function nextStep(from){
  if(from===1 && !validateS1()) return;
  if(from===2 && !validateS2()) return;
  if(from===1){ renderPD(); gotoStep(2); }
  else if(from===2){ renderSummary(); gotoStep(3); }
}

function prevStep(from){ gotoStep(from-1); }

// ================================================================
// RENDER PAYMENTS (STEP 1)
// ================================================================

function renderPays(){
  const w=document.getElementById('payments-wrap');
  w.innerHTML='';
  S.payments.forEach((p,i)=>{
    const can=S.payments.length>1;
    const bilTag = p.billing==='direct_bill'
      ? `<span class="btag bd">⬤ Direct Bill — Autofinanciada</span>`
      : p.billing==='agency_bill'
      ? `<span class="btag ba">◯ Agency Bill</span>` : '';

    const div=document.createElement('div');
    div.className='card pe';
    div.innerHTML=`
      <div class="peh">
        <span>Póliza ${i+1}</span>
        ${can?`<button class="rmbtn" onclick="rmPay(${i})" title="Eliminar póliza">×</button>`:''}
      </div>
      <div class="fg2">
        <div class="fg acw" id="cg-${i}">
          <label>Compañía de Seguros *</label>
          <input type="text" id="ci-${i}" placeholder="Buscar compañía…" value="${p.compania}"
                 autocomplete="off"
                 oninput="srchC(${i},this.value)"
                 onfocus="srchC(${i},this.value)"
                 onblur="hideL('cl-${i}',180)">
          <div class="acl" id="cl-${i}"></div>
          <span class="ie">Seleccione una compañía</span>
          ${bilTag}
        </div>
        <div class="fg acw" id="fg-${i}" ${p.selfFin?'style="opacity:.5"':''}>
          <label>Financiera / MGA *</label>
          <input type="text" id="fi-${i}" placeholder="${p.selfFin?'Autofinanciada (sin financiera)':'Buscar financiera o MGA…'}"
                 value="${p.financiera}" autocomplete="off"
                 ${p.selfFin?'disabled':''}
                 oninput="srchF(${i},this.value)"
                 onfocus="srchF(${i},this.value)"
                 onblur="hideL('fl-${i}',180)">
          <div class="acl" id="fl-${i}"></div>
          <span class="ie">Seleccione una financiera / MGA</span>
        </div>
      </div>
    `;
    w.appendChild(div);
  });
}

function addPayment(){ S.payments.push(mkPay()); renderPays(); }
function rmPay(i){ if(S.payments.length<=1) return; S.payments.splice(i,1); renderPays(); }

// ================================================================
// AUTOCOMPLETE
// ================================================================

function srchC(i,q){
  const list=document.getElementById('cl-'+i);
  const hits=COMPANIES.filter(c=>c.name.toLowerCase().includes(q.toLowerCase()));
  list.innerHTML='';
  if(!hits.length){ list.classList.remove('open'); return; }
  hits.forEach(c=>{
    const d=document.createElement('div');
    d.className='aci';
    const tc=c.autoStudy?'t-special':c.billing==='direct_bill'?'t-direct':'t-agency';
    const tt=c.autoStudy?'Estudio Auto':c.billing==='direct_bill'?'Direct Bill':'Agency Bill';
    d.innerHTML=`<span>${c.name}</span><span class="atag ${tc}">${tt}</span>`;
    d.onmousedown=()=>selC(i,c);
    list.appendChild(d);
  });
  list.classList.add('open');
}

function selC(i,c){
  const p=S.payments[i];
  p.compania=c.name; p.companiaObj=c;
  p.billing=c.billing; p.selfFin=c.selfFinance||false;
  if(p.selfFin){ p.financiera=''; p.financieraObj=null; }
  if(c.autoStudy){ p.financiera='Progressive'; p.financieraObj=FINANCIERAS[0]; }
  renderPays();
}

function srchF(i,q){
  if(S.payments[i].selfFin) return;
  const list=document.getElementById('fl-'+i);
  const hits=FINANCIERAS.filter(f=>f.name.toLowerCase().includes(q.toLowerCase()));
  list.innerHTML='';
  if(!hits.length){ list.classList.remove('open'); return; }
  hits.forEach(f=>{
    const d=document.createElement('div');
    d.className='aci';
    const tc=f.autoStudy?'t-special':'t-agency';
    const tt=f.autoStudy?'⚡ Estudio Automático':'Financiera / MGA';
    d.innerHTML=`<span>${f.name}</span><span class="atag ${tc}">${tt}</span>`;
    d.onmousedown=()=>selF(i,f);
    list.appendChild(d);
  });
  list.classList.add('open');
}

function selF(i,f){
  S.payments[i].financiera=f.name;
  S.payments[i].financieraObj=f;
  renderPays();
}

function hideL(id,ms){ setTimeout(()=>{ const el=document.getElementById(id); if(el) el.classList.remove('open'); },ms); }

// ================================================================
// RENDER PAYMENT DETAILS (STEP 2)
// ================================================================

function renderPD(){
  const w=document.getElementById('pd-wrap');
  w.innerHTML='';
  S.payments.forEach((p,i)=>{
    const isDirect=p.billing==='direct_bill';
    const minPct=isDirect?100:70;
    const curPct=Math.max(p.pctP1||minPct, minPct);
    p.pctP1=curPct;

    const div=document.createElement('div');
    div.className='card';
    div.innerHTML=`
      <div class="ct">
        Detalles de Pago
        <small>${p.compania}${p.financiera?' · '+p.financiera:''}</small>
      </div>
      <div class="fg2">
        <div class="fg" id="g-dp-${i}">
          <label>Total Down Payment ($) *</label>
          <input type="number" id="dp-${i}" placeholder="0.00" min="0" step="0.01" value="${p.totalDP||''}"
                 oninput="upd(${i},'totalDP',this.value);updPreview(${i})">
          <span class="ie">Ingrese el monto del Down Payment</span>
        </div>
        <div class="fg" id="g-fp-${i}">
          <label>Fecha del Primer Pago *</label>
          <input type="date" id="fp-${i}" value="${p.fechaP1||''}"
                 oninput="upd(${i},'fechaP1',this.value);updPreview(${i})">
          <span class="ie">Seleccione la fecha del primer pago</span>
        </div>
        <div class="fg full" id="g-pct-${i}">
          <label>% Primer Pago * <span class="hint">(mínimo ${minPct}% — segundo pago es el restante)</span></label>
          <div class="rw">
            <input type="range" id="rng-${i}" min="${minPct}" max="100" step="1" value="${curPct}"
                   oninput="updPct(${i},this.value)">
            <div class="rv" id="rv-${i}">${curPct}%</div>
          </div>
          <span class="ie" id="pct-err-${i}">El primer pago debe ser mínimo ${minPct}%</span>
        </div>
        <div class="fg" id="g-dias-${i}">
          <label>Días al Segundo Pago * <span class="hint">(máximo 12 días)</span></label>
          <input type="number" id="dias-${i}" placeholder="1 – 12" min="1" max="12" value="${p.diasP2||''}"
                 oninput="upd(${i},'diasP2',this.value);updPreview(${i})">
          <span class="ie">Ingrese entre 1 y 12 días</span>
        </div>
        <div class="fg">
          <label>Comentarios <span class="hint">(opcional)</span></label>
          <textarea id="com-${i}" placeholder="Notas o aclaraciones adicionales…"
                    oninput="upd(${i},'comentarios',this.value)">${p.comentarios||''}</textarea>
        </div>
      </div>
      <div class="pvbox" id="pv-${i}">
        <div class="pvtitle">Vista Previa del Diferido</div>
        <div id="pvc-${i}"><div class="pv-empty">Complete los campos para ver la vista previa</div></div>
      </div>
    `;
    w.appendChild(div);
    updPreview(i);
  });
}

function upd(i,f,v){ S.payments[i][f]=v; }

function updPct(i,v){
  S.payments[i].pctP1=parseInt(v);
  const d=document.getElementById('rv-'+i); if(d) d.textContent=v+'%';
  const r=document.getElementById('rng-'+i); if(r) r.value=v;
  updPreview(i);
}

function updPreview(i){
  const p=S.payments[i];
  const total=parseFloat(p.totalDP)||0;
  const pct=parseInt(p.pctP1)||70;
  const dias=parseInt(p.diasP2)||0;

  if(total<=0){ return; }

  const p1=total*(pct/100);
  const p2=total-p1;

  const fmtM=n=>n.toLocaleString('en-US',{style:'currency',currency:'USD'});
  const fmtD=s=>{
    if(!s) return '—';
    const d=new Date(s+'T00:00:00');
    return d.toLocaleDateString('en-US',{month:'2-digit',day:'2-digit',year:'numeric'});
  };

  let f2='—';
  if(p.fechaP1 && dias>0){
    const d2=new Date(p.fechaP1+'T00:00:00');
    d2.setDate(d2.getDate()+dias);
    f2=d2.toLocaleDateString('en-US',{month:'2-digit',day:'2-digit',year:'numeric'});
  }

  const c=document.getElementById('pvc-'+i);
  if(!c) return;
  c.innerHTML=`
    <div class="pvr"><span class="pvl">Total Down Payment</span><span class="pvv hl">${fmtM(total)}</span></div>
    <div class="pvr"><span class="pvl">Primer Pago (${pct}%)</span><span class="pvv">${fmtM(p1)}</span></div>
    <div class="pvr"><span class="pvl">Fecha Primer Pago</span><span class="pvv">${fmtD(p.fechaP1)}</span></div>
    <div class="pvr"><span class="pvl">Segundo Pago (${100-pct}%)</span><span class="pvv">${fmtM(p2)}</span></div>
    <div class="pvr"><span class="pvl">Días al Segundo Pago</span><span class="pvv">${dias} día${dias!==1?'s':''}</span></div>
    <div class="pvr"><span class="pvl">Fecha Segundo Pago</span><span class="pvv">${f2}</span></div>
  `;
}

// ================================================================
// VALIDATION
// ================================================================

function setErr(id,hasErr){
  const el=document.getElementById(id);
  if(el) hasErr?el.classList.add('he'):el.classList.remove('he');
}

function validateS1(){
  let ok=true;
  const req=['agenteName','agenteEmail','referencia','dot'];
  req.forEach(id=>{
    const v=document.getElementById(id)?.value?.trim();
    const bad=!v||(id==='agenteEmail'&&!v.includes('@'));
    setErr('g-'+id,bad);
    if(bad) ok=false;
  });
  S.payments.forEach((p,i)=>{
    const c1=!p.compania; setErr('cg-'+i,c1); if(c1) ok=false;
    const c2=!p.selfFin&&!p.financiera; setErr('fg-'+i,c2); if(c2) ok=false;
  });
  if(!ok) toast('Por favor complete todos los campos requeridos','err');
  return ok;
}

function validateS2(){
  let ok=true;
  S.payments.forEach((p,i)=>{
    const isDirect=p.billing==='direct_bill';
    const minPct=isDirect?100:70;

    const d1=!p.totalDP||parseFloat(p.totalDP)<=0;
    setErr('g-dp-'+i,d1); if(d1) ok=false;

    const d2=!p.fechaP1;
    setErr('g-fp-'+i,d2); if(d2) ok=false;

    const pct=parseInt(p.pctP1);
    const d3=pct<minPct;
    setErr('g-pct-'+i,d3);
    const pe=document.getElementById('pct-err-'+i);
    if(pe) pe.style.display=d3?'block':'none';
    if(d3) ok=false;

    const dias=parseInt(p.diasP2);
    const d4=!p.diasP2||dias<1||dias>12;
    setErr('g-dias-'+i,d4); if(d4) ok=false;
  });
  if(!ok) toast('Corrija los errores antes de continuar','err');
  return ok;
}

// ================================================================
// EVALUATION LOGIC (SCENARIOS FROM CSV)
// ================================================================
/*
  Scenario 1 – Direct bill (autofinancia): 100% DP → auto-approve
  Scenario 2 – Agency bill ≥70% → auto-approve
  Scenario 3 – Direct+Agency: 100% direct + ≥70% agency → auto-approve
  Scenario 4 – Agency bill that may become Direct bill → PENDING
  Scenario 5 – Agency bill <70% → PENDING (form prevents but safety-check)
  Scenario 6 – Direct bill <100% → PENDING
  Special     – Progressive as financiera → ALWAYS auto-study (PENDING)
*/

function evalReq(pays){
  for(const p of pays){
    // Special: Progressive → always study
    if((p.financieraObj&&p.financieraObj.autoStudy)||(p.companiaObj&&p.companiaObj.autoStudy)){
      return{status:'pending',reason:'Financiera Progressive detectada — estudio de diferidos iniciado automáticamente.',scenario:'Special'};
    }
    // Scenario 6: direct bill < 100%
    if(p.billing==='direct_bill'&&parseInt(p.pctP1)<100){
      return{status:'pending',reason:`Direct bill con ${p.pctP1}% del DP (se requiere 100%) — requiere aprobación del área de crédito. (Escenario 6)`,scenario:6};
    }
    // Scenario 5: agency bill < 70% (safety)
    if(p.billing==='agency_bill'&&parseInt(p.pctP1)<70){
      return{status:'pending',reason:`Agency bill con ${p.pctP1}% del DP (se requiere mínimo 70%) — requiere aprobación del área de crédito. (Escenario 5)`,scenario:5};
    }
  }

  // Scenario 3: mixed billing
  const hasDirect=pays.some(p=>p.billing==='direct_bill'&&!p.selfFin);
  const hasAgency=pays.some(p=>p.billing==='agency_bill');
  if(hasDirect&&hasAgency){
    const allOk=pays.every(p=>{
      if(p.billing==='direct_bill') return parseInt(p.pctP1)>=100;
      if(p.billing==='agency_bill') return parseInt(p.pctP1)>=70;
      return true;
    });
    return allOk
      ?{status:'approved',reason:'Direct bill (100%) + Agency bill (≥70%) — condiciones cumplidas. Aprobación automática. (Escenario 3)',scenario:3}
      :{status:'pending',reason:'Combinación Direct bill + Agency bill requiere revisión. (Escenario 3)',scenario:3};
  }

  // Scenario 1: direct bill 100%
  if(pays.every(p=>p.billing==='direct_bill')&&pays.every(p=>parseInt(p.pctP1)>=100)){
    return{status:'approved',reason:'Direct bill con 100% del DP — aprobación automática. (Escenario 1)',scenario:1};
  }

  // Scenario 2: agency bill ≥70%
  return{status:'approved',reason:'Agency bill con ≥70% del DP — condiciones cumplidas. Aprobación automática. (Escenario 2)',scenario:2};
}

// ================================================================
// SUMMARY (STEP 3)
// ================================================================

function renderSummary(){
  const an=document.getElementById('agenteName').value;
  const ae=document.getElementById('agenteEmail').value;
  const ref=document.getElementById('referencia').value;
  const dot=document.getElementById('dot').value;
  const ev=evalReq(S.payments);
  S.evalResult=ev;
  S.snapForm={an,ae,ref,dot,pays:JSON.parse(JSON.stringify(S.payments))};

  const fmtM=n=>parseFloat(n||0).toLocaleString('en-US',{style:'currency',currency:'USD'});
  const fmtD=s=>{if(!s)return'—';const d=new Date(s+'T00:00:00');return d.toLocaleDateString('en-US',{month:'2-digit',day:'2-digit',year:'numeric'});};

  let html=`
    <div class="sum-sec">
      <div class="sum-sec-title">Información del Agente</div>
      <div class="sum-row"><span class="sum-lbl">Agente</span><span class="sum-val">${an}</span></div>
      <div class="sum-row"><span class="sum-lbl">Correo</span><span class="sum-val">${ae}</span></div>
      <div class="sum-row"><span class="sum-lbl">Referencia</span><span class="sum-val">${ref}</span></div>
      <div class="sum-row"><span class="sum-lbl">DOT</span><span class="sum-val">${dot}</span></div>
    </div>
  `;

  S.payments.forEach((p,i)=>{
    const pct=parseInt(p.pctP1);
    const total=parseFloat(p.totalDP);
    const p1=total*(pct/100), p2=total-p1;
    let f2='—';
    if(p.fechaP1&&p.diasP2){
      const d2=new Date(p.fechaP1+'T00:00:00'); d2.setDate(d2.getDate()+parseInt(p.diasP2));
      f2=d2.toLocaleDateString('en-US',{month:'2-digit',day:'2-digit',year:'numeric'});
    }
    html+=`
      <div class="sum-sec">
        <div class="sum-sec-title">Póliza ${i+1} — ${p.compania}</div>
        <div class="sum-row"><span class="sum-lbl">Financiera / MGA</span><span class="sum-val">${p.financiera||'Autofinanciada'}</span></div>
        <div class="sum-row"><span class="sum-lbl">Facturación</span><span class="sum-val">${p.billing==='direct_bill'?'Direct Bill':'Agency Bill'}</span></div>
        <div class="sum-row"><span class="sum-lbl">Total Down Payment</span><span class="sum-val">${fmtM(total)}</span></div>
        <div class="sum-row"><span class="sum-lbl">Primer Pago (${pct}%)</span><span class="sum-val">${fmtM(p1)} — ${fmtD(p.fechaP1)}</span></div>
        <div class="sum-row"><span class="sum-lbl">Segundo Pago (${100-pct}%)</span><span class="sum-val">${fmtM(p2)} — ${f2} (${p.diasP2} días)</span></div>
        ${p.comentarios?`<div class="sum-row"><span class="sum-lbl">Comentarios</span><span class="sum-val">${p.comentarios}</span></div>`:''}
      </div>
    `;
  });

  document.getElementById('summary-html').innerHTML=html;

  const st=ev.status;
  const badgeHtml=st==='approved'?`<span class="badge b-appr">Aprobación Automática</span>`:`<span class="badge b-pend">Enviada a Revisión de Créditos</span>`;
  const alertCls=st==='approved'?'a-ok':'a-pend';
  const icon=st==='approved'?'✓':'⏳';
  document.getElementById('eval-html').innerHTML=`
    <div style="margin-bottom:1rem">${badgeHtml}</div>
    <div class="alert ${alertCls}"><span>${icon}</span><span>${ev.reason}</span></div>
  `;
}

// ================================================================
// SUBMIT
// ================================================================

function submitRequest(){
  const {an,ae,ref,dot,pays}=S.snapForm||{};
  const ev=S.evalResult||{status:'pending',reason:'Pendiente'};
  const req={
    id:'DIF-'+Date.now(),
    submittedAt:new Date().toISOString(),
    status:ev.status,
    evalReason:ev.reason,
    scenario:ev.scenario,
    agenteName:an, agenteEmail:ae, referencia:ref, dot,
    payments:pays,
    reviewNotes:'', reviewedAt:null
  };
  upsertReq(req);

  // Reset
  initPayments();
  gotoStep(1);
  ['agenteName','agenteEmail','referencia','dot'].forEach(id=>{
    const el=document.getElementById(id); if(el) el.value='';
  });

  if(ev.status==='approved')
    toast('✓ Solicitud aprobada automáticamente — '+req.id);
  else
    toast('⏳ Solicitud enviada a revisión — '+req.id);
}

// ================================================================
// REQUESTS LIST (PAGE 2)
// ================================================================

function renderReqList(){
  const srch=(document.getElementById('srch')?.value||'').toLowerCase();
  const sf=document.getElementById('sf-status')?.value||'';
  const df=document.getElementById('sf-date')?.value||'';
  let reqs=getReqs();

  if(srch) reqs=reqs.filter(r=>
    r.agenteName?.toLowerCase().includes(srch)||
    r.referencia?.toLowerCase().includes(srch)||
    r.dot?.toLowerCase().includes(srch)||
    r.id?.toLowerCase().includes(srch)
  );
  if(sf) reqs=reqs.filter(r=>r.status===sf);
  if(df){
    const now=new Date();
    reqs=reqs.filter(r=>{
      const d=new Date(r.submittedAt);
      if(df==='today') return d.toDateString()===now.toDateString();
      if(df==='week') return (now-d)<7*864e5;
      if(df==='month') return (now-d)<30*864e5;
    });
  }

  const el=document.getElementById('req-list');
  if(!reqs.length){ el.innerHTML=`<div class="no-data">No se encontraron solicitudes</div>`; return; }

  el.innerHTML=`<table>
    <thead><tr><th>ID</th><th>Agente</th><th>Referencia</th><th>DOT</th><th>Fecha</th><th>Estado</th><th></th></tr></thead>
    <tbody>${reqs.map(r=>`<tr>
      <td><code style="font-size:.76rem;color:var(--g500)">${r.id}</code></td>
      <td>${r.agenteName||'—'}</td>
      <td>${r.referencia||'—'}</td>
      <td>${r.dot||'—'}</td>
      <td style="font-size:.78rem;color:var(--g500)">${fmtDt(r.submittedAt)}</td>
      <td>${bHtml(r.status)}</td>
      <td><button class="btn btn-ghost" style="padding:4px 10px;font-size:.73rem" onclick="openModal('${r.id}',false)">Ver →</button></td>
    </tr>`).join('')}</tbody>
  </table>`;
}

// ================================================================
// CREDITS DASHBOARD (PAGE 3)
// ================================================================

function checkPw(){
  const pw=document.getElementById('cr-pw').value;
  if(pw==='Credit2026'){
    S.creditAuth=true;
    document.getElementById('cr-login').style.display='none';
    document.getElementById('cr-dash').style.display='block';
    document.getElementById('pw-err').style.display='none';
    renderCrDash();
  } else {
    document.getElementById('pw-err').style.display='block';
    document.getElementById('cr-pw').value='';
  }
}

function logoutCr(){
  S.creditAuth=false;
  document.getElementById('cr-login').style.display='block';
  document.getElementById('cr-dash').style.display='none';
  document.getElementById('cr-pw').value='';
}

function renderCrDash(){
  const all=getReqs();
  const pend=all.filter(r=>r.status==='pending');
  const appr=all.filter(r=>r.status==='approved');
  const reje=all.filter(r=>r.status==='rejected');

  document.getElementById('st-pend').textContent=pend.length;
  document.getElementById('st-appr').textContent=appr.length;
  document.getElementById('st-reje').textContent=reje.length;

  const pl=document.getElementById('cr-pend-list');
  if(!pend.length){
    pl.innerHTML=`<div class="no-data">No hay solicitudes pendientes de revisión ✓</div>`;
  } else {
    pl.innerHTML=`<table>
      <thead><tr><th>ID</th><th>Agente</th><th>Referencia</th><th>DOT</th><th>Fecha</th><th>Motivo</th><th></th></tr></thead>
      <tbody>${pend.map(r=>`<tr>
        <td><code style="font-size:.76rem">${r.id}</code></td>
        <td>${r.agenteName||'—'}</td><td>${r.referencia||'—'}</td><td>${r.dot||'—'}</td>
        <td style="font-size:.76rem;color:var(--g500)">${fmtDt(r.submittedAt)}</td>
        <td style="font-size:.76rem;color:var(--g500);max-width:180px">${(r.evalReason||'').substring(0,60)}…</td>
        <td><button class="btn btn-p" style="padding:6px 14px;font-size:.73rem" onclick="openModal('${r.id}',true)">Revisar</button></td>
      </tr>`).join('')}</tbody>
    </table>`;
  }

  const al=document.getElementById('cr-all-list');
  if(!all.length){
    al.innerHTML=`<div class="no-data">No hay solicitudes registradas aún</div>`;
  } else {
    al.innerHTML=`<table>
      <thead><tr><th>ID</th><th>Agente</th><th>Referencia</th><th>DOT</th><th>Fecha</th><th>Estado</th><th></th></tr></thead>
      <tbody>${all.map(r=>`<tr>
        <td><code style="font-size:.76rem">${r.id}</code></td>
        <td>${r.agenteName||'—'}</td><td>${r.referencia||'—'}</td><td>${r.dot||'—'}</td>
        <td style="font-size:.76rem;color:var(--g500)">${fmtDt(r.submittedAt)}</td>
        <td>${bHtml(r.status)}</td>
        <td><button class="btn btn-ghost" style="padding:4px 10px;font-size:.73rem" onclick="openModal('${r.id}',${r.status==='pending'&&S.creditAuth})">Ver →</button></td>
      </tr>`).join('')}</tbody>
    </table>`;
  }
}

// ================================================================
// REVIEW MODAL
// ================================================================

function openModal(rid, canReview){
  const all=getReqs();
  const r=all.find(x=>x.id===rid);
  if(!r) return;
  S.reviewId=rid;

  const fmtM=n=>parseFloat(n||0).toLocaleString('en-US',{style:'currency',currency:'USD'});
  const fmtD=s=>{if(!s)return'—';const d=new Date(s+'T00:00:00');return d.toLocaleDateString('en-US',{month:'2-digit',day:'2-digit',year:'numeric'});};

  let polHTML='';
  (r.payments||[]).forEach((p,i)=>{
    const pct=parseInt(p.pctP1);
    const total=parseFloat(p.totalDP);
    const p1=total*(pct/100),p2=total-p1;
    let f2='—';
    if(p.fechaP1&&p.diasP2){
      const d2=new Date(p.fechaP1+'T00:00:00');d2.setDate(d2.getDate()+parseInt(p.diasP2));
      f2=d2.toLocaleDateString('en-US',{month:'2-digit',day:'2-digit',year:'numeric'});
    }
    polHTML+=`
      <div style="border:1px solid var(--g200);border-radius:6px;padding:1.1rem;margin-bottom:.9rem">
        <div style="font-size:.67rem;font-weight:700;text-transform:uppercase;letter-spacing:.09em;color:var(--g500);margin-bottom:.75rem">Póliza ${i+1}</div>
        <div class="dg">
          <div class="di"><div class="dl">Compañía</div><div class="dv">${p.compania||'—'}</div></div>
          <div class="di"><div class="dl">Financiera / MGA</div><div class="dv">${p.financiera||'Autofinanciada'}</div></div>
          <div class="di"><div class="dl">Tipo</div><div class="dv">${p.billing==='direct_bill'?'Direct Bill':'Agency Bill'}</div></div>
          <div class="di"><div class="dl">Total Down Payment</div><div class="dv">${fmtM(total)}</div></div>
          <div class="di"><div class="dl">Primer Pago (${pct}%)</div><div class="dv">${fmtM(p1)} — ${fmtD(p.fechaP1)}</div></div>
          <div class="di"><div class="dl">Segundo Pago (${100-pct}%)</div><div class="dv">${fmtM(p2)} — ${f2}</div></div>
          ${p.comentarios?`<div class="di" style="grid-column:1/-1"><div class="dl">Comentarios</div><div class="dv">${p.comentarios}</div></div>`:''}
        </div>
      </div>
    `;
  });

  // Email templates
  const eSub=`Diferido Aprobado – Ref. ${r.referencia} | ${r.id}`;
  const eBody=`Estimado/a ${r.agenteName},\n\nNos complace informarle que su solicitud de diferido ha sido aprobada exitosamente.\n\nDetalles:\n• ID: ${r.id}\n• Referencia: ${r.referencia}\n• DOT: ${r.dot}\n\nPor favor proceda con los trámites correspondientes. Si tiene alguna duda, no dude en contactarnos.\n\nAtentamente,\nÁrea de Créditos`;

  document.getElementById('modal-body').innerHTML=`
    <div class="dg" style="margin-bottom:1.5rem">
      <div class="di"><div class="dl">ID Solicitud</div><div class="dv"><code style="font-size:.85rem">${r.id}</code></div></div>
      <div class="di"><div class="dl">Estado</div><div class="dv">${bHtml(r.status)}</div></div>
      <div class="di"><div class="dl">Agente</div><div class="dv">${r.agenteName||'—'}</div></div>
      <div class="di"><div class="dl">Correo</div><div class="dv">${r.agenteEmail||'—'}</div></div>
      <div class="di"><div class="dl">Referencia</div><div class="dv">${r.referencia||'—'}</div></div>
      <div class="di"><div class="dl">DOT</div><div class="dv">${r.dot||'—'}</div></div>
      <div class="di" style="grid-column:1/-1"><div class="dl">Evaluación del Sistema</div><div class="dv" style="color:var(--g500);font-size:.84rem">${r.evalReason||'—'}</div></div>
      ${r.reviewNotes?`<div class="di" style="grid-column:1/-1"><div class="dl">Notas de Revisión</div><div class="dv">${r.reviewNotes}</div></div>`:''}
      ${r.reviewedAt?`<div class="di"><div class="dl">Revisado</div><div class="dv" style="font-size:.82rem">${fmtDt(r.reviewedAt)}</div></div>`:''}
    </div>

    ${polHTML}

    <div class="email-box">
      <div class="email-box-title">📧 Redactar Correo al Agente</div>
      <div class="fg" style="margin-bottom:.6rem">
        <label>Para</label>
        <input type="email" id="e-to" value="${r.agenteEmail||''}" placeholder="correo@agencia.com">
      </div>
      <div class="fg" style="margin-bottom:.6rem">
        <label>Asunto</label>
        <input type="text" id="e-sub" value="${eSub}">
      </div>
      <div class="fg" style="margin-bottom:.6rem">
        <label>Mensaje</label>
        <textarea id="e-body" rows="6">${eBody}</textarea>
      </div>
      <div style="display:flex;gap:.5rem;flex-wrap:wrap;margin-top:.5rem">
        <button class="btn btn-s" style="font-size:.72rem;padding:7px 12px"
                onclick="loadTpl('ok','${esc(r.agenteName)}','${esc(r.referencia)}','${r.id}','${r.dot}','${r.agenteEmail||''}')">
          Plantilla Aprobación
        </button>
        <button class="btn btn-s" style="font-size:.72rem;padding:7px 12px"
                onclick="loadTpl('no','${esc(r.agenteName)}','${esc(r.referencia)}','${r.id}','${r.dot}','${r.agenteEmail||''}')">
          Plantilla Rechazo
        </button>
        <button class="btn btn-p" style="font-size:.72rem;padding:7px 12px" onclick="sendMail()">
          Abrir en Correo ✉
        </button>
      </div>
    </div>
  `;

  let acts='';
  if(canReview && r.status==='pending'){
    acts=`
      <div class="fg" style="flex:1;min-width:180px">
        <label style="font-size:.65rem;font-weight:700;text-transform:uppercase;letter-spacing:.09em;color:var(--g500)">Notas de revisión <span style="font-weight:400;text-transform:none">(opcional)</span></label>
        <input type="text" id="rnotes" placeholder="Agregar notas o motivo…"
               style="border:1px solid var(--g200)!important;border-radius:4px!important;padding:8px 12px!important;background:var(--white)!important">
      </div>
      <button class="btn btn-ok" onclick="processReq('approved')">✓ Aprobar</button>
      <button class="btn btn-no" onclick="processReq('rejected')">✗ Rechazar</button>
    `;
  } else {
    acts=`<span style="font-size:.82rem;color:var(--g500)">Vista de solo lectura</span>`;
  }
  document.getElementById('modal-actions').innerHTML=acts;
  document.getElementById('modal').classList.add('open');
}

function closeModal(){ document.getElementById('modal').classList.remove('open'); }

function esc(s){ return (s||'').replace(/'/g,"\\'"); }

function loadTpl(type,an,ref,id,dot,email){
  const sub=document.getElementById('e-sub');
  const body=document.getElementById('e-body');
  const to=document.getElementById('e-to');
  if(to) to.value=email||'';
  if(type==='ok'){
    if(sub) sub.value=`Diferido Aprobado – Ref. ${ref} | ${id}`;
    if(body) body.value=`Estimado/a ${an},\n\nNos complace informarle que su solicitud de diferido ha sido aprobada exitosamente.\n\nDetalles de la solicitud:\n• ID: ${id}\n• Referencia: ${ref}\n• DOT: ${dot}\n\nPor favor proceda con los trámites correspondientes. Ante cualquier duda, estamos a su disposición.\n\nAtentamente,\nÁrea de Créditos`;
  } else {
    if(sub) sub.value=`Diferido No Aprobado – Ref. ${ref} | ${id}`;
    if(body) body.value=`Estimado/a ${an},\n\nLamentamos informarle que su solicitud de diferido (Ref. ${ref} / ID: ${id}) no ha podido ser procesada en esta ocasión.\n\nMotivo: [Favor completar con el motivo específico de rechazo]\n\nLe recomendamos revisar los criterios de diferidos vigentes y, de ser necesario, volver a gestionar la solicitud con las correcciones correspondientes.\n\nPara consultas adicionales, comuníquese directamente con el área de créditos.\n\nAtentamente,\nÁrea de Créditos`;
  }
}

function sendMail(){
  const to=document.getElementById('e-to')?.value||'';
  const sub=document.getElementById('e-sub')?.value||'';
  const body=document.getElementById('e-body')?.value||'';
  window.open(`mailto:${encodeURIComponent(to)}?subject=${encodeURIComponent(sub)}&body=${encodeURIComponent(body)}`,'_blank');
}

function processReq(ns){
  const notes=document.getElementById('rnotes')?.value||'';
  const all=getReqs();
  const i=all.findIndex(r=>r.id===S.reviewId);
  if(i<0) return;
  all[i].status=ns;
  all[i].reviewNotes=notes;
  all[i].reviewedAt=new Date().toISOString();
  saveReqs(all);
  closeModal();
  renderCrDash();
  toast(ns==='approved'?'✓ Solicitud aprobada':'✗ Solicitud rechazada');
}

// ================================================================
// HELPERS
// ================================================================

function fmtDt(iso){
  if(!iso) return '—';
  return new Date(iso).toLocaleDateString('en-US',{month:'2-digit',day:'2-digit',year:'numeric',hour:'2-digit',minute:'2-digit'});
}

function bHtml(s){
  if(s==='approved') return `<span class="badge b-appr">Aprobado</span>`;
  if(s==='rejected') return `<span class="badge b-reje">Rechazado</span>`;
  return `<span class="badge b-pend">Pendiente</span>`;
}

function toast(msg,type){
  const t=document.getElementById('toast');
  t.textContent=msg;
  t.style.background=type==='err'?'var(--red)':'var(--black)';
  t.classList.add('show');
  setTimeout(()=>t.classList.remove('show'),3800);
}

// ================================================================
// INIT
// ================================================================

document.addEventListener('DOMContentLoaded',()=>{
  initPayments();
});

document.getElementById('modal').addEventListener('click',function(e){
  if(e.target===this) closeModal();
});
</script>
</body>
</html>
